# Required API Keys
GOOGLE_API_KEY=your_actual_api_key_here
HF_TOKEN=your_huggingface_token_here

# Environment Settings
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Weaviate Configuration
WEAVIATE_HOST=localhost
WEAVIATE_PORT=8081
WEAVIATE_SCHEME=http
WEAVIATE_COLLECTION=PoliticalStatement

# Model Configuration - KEEPING YOUR EXISTING MODELS
GEMINI_MODEL=models/gemini-flash-latest
GEMINI_TEMPERATURE=0.1
GEMINI_MAX_TOKENS=2048

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma:2b-instruct

# Embedder - YOUR EXISTING MODEL
EMBEDDER_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBEDDER_DEVICE=cuda

# Reranker - YOUR EXISTING MODEL  
RERANKER_MODEL=Qwen/Qwen3-Reranker-0.6B
RERANKER_TOP_K=10

# Retrieval Settings
INITIAL_CANDIDATES=50
RERANK_CANDIDATES=20

# File Paths - YOUR EXISTING DATA PATHS
PATHS__EMBEDDINGS_PATH=C:\db\Gemini_Generated_Json\mk_stalin\mk_stalin_embeddings.npy
PATHS__EMBEDDING_MAP_PATH=C:\db\Gemini_Generated_Json\mk_stalin\mk_stalin_embedding_map.json
PATHS__SOURCE_ARTICLE_PATH=C:\db\Gemini_Generated_Json\mk_stalin\mk_stalin_consolidated_articles_excluding_none.json